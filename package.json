{
    "name": "pos-antigravity",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "install-all": "npm install && cd client && npm install && cd ../server && npm install",
        "dev": "concurrently \"npm run dev --prefix client -- --host\" \"node server.js\"",
        "dev:all": "concurrently \"npm run dev --prefix client -- --host\" \"node server.js\"",
        "start": "concurrently \"node server.js\" \"npm run dev --prefix client\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "mysql2": "^3.19.0",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    }
}
