{
    "name": "pos-antigravity",
    "version": "1.0.0",
    "private": true,
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "install-all": "npm install && cd client && npm install",
        "build": "cd client && npm install && npm run build",
        "start": "node server.js",
        "dev": "concurrently \"npm run dev --prefix client -- --host\" \"node server.js\"",
        "dev:all": "concurrently \"npm run dev --prefix client -- --host\" \"node server.js\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.99.0",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3"
    }
}
